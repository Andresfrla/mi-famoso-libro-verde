{
  "expo": {
    "name": "Mi Famoso Libro Verde",
    "slug": "mi-libro-verde",
    "version": "1.1.3",
    "orientation": "portrait",
    "icon": "./assets/images/logo-app.png",
    "scheme": ["milibroverde", "exp"],
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.milibroverde.app"
    },
    "android": {
      "versionCode": 100006,
      "adaptiveIcon": {
        "backgroundColor": "#22C55E",
        "foregroundImage": "./assets/images/logo-app.png",
        "backgroundImage": "./assets/images/logo-app.png",
        "monochromeImage": "./assets/images/logo-app.png"
      },
      "package": "com.milibroverde.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": ["android.permission.RECORD_AUDIO"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo-app.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F6F8F6",
          "dark": {
            "backgroundColor": "#102210"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "La aplicaci\u00f3n necesita acceso a tus fotos para subir im\u00e1genes de recetas.",
          "cameraPermission": "La aplicaci\u00f3n necesita acceso a la c\u00e1mara para tomar fotos de recetas."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~1458000111"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "6ce9bfb9-40c9-48f3-933d-2734cb80df25"
      },
      "router": {}
    }
  }
}
